---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getPath } from "@/utils/getPath";
import postFilter from "@/utils/postFilter";
import { SITE } from "@/config";

const books = (await getCollection("blog"))
  .filter(post => postFilter(post))
  .filter(({ data }) => (data.tags || []).includes("book"))
  .sort((a, b) => +new Date(b.data.pubDatetime) - +new Date(a.data.pubDatetime));

function formatDate(date: Date) {
  return new Intl.DateTimeFormat("en-GB", {
    month: "short",
    year: "numeric",
  }).format(date);
}

function getBookType(tags: string[] = []) {
  if (tags.includes("book-reflection")) return "Reflections";
  if (tags.includes("book-notes")) return "Notes";
  return "Reading";
}
---

<Layout title={`Books | ${SITE.title}`}>
  <Header />

  <main class="mx-auto max-w-3xl px-4 sm:px-6 pb-16">
    <header class="pt-4 mb-10">
      <h1 class="text-4xl font-extrabold mb-2">Books</h1>
      <p class="text-foreground/60 max-w-2xl">
        Notes and reflections from my reading.
      </p>
    </header>

    {books.length > 0 ? (
      <ul class="space-y-5">
        {books.map((book) => (
          <li class="group border border-border border-l-4 border-l-accent rounded-lg p-5 transition-all duration-200 hover:border-accent hover:bg-muted/30 hover:shadow-sm">
            <div class="flex items-start justify-between gap-3 mb-3">
              <span class="inline-flex items-center gap-2 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider rounded-full bg-accent/10 text-accent">
                {getBookType(book.data.tags)}
              </span>
              <time
                datetime={book.data.pubDatetime.toISOString()}
                class="text-sm text-foreground/60 whitespace-nowrap"
              >
                {formatDate(book.data.pubDatetime)}
              </time>
            </div>
            <a
              href={getPath(book.id, book.filePath)}
              class="block text-xl font-semibold text-accent decoration-dashed underline-offset-4 group-hover:underline"
            >
              {book.data.title}
            </a>
            {book.data.draft && (
              <span class="mt-1 inline-flex items-center rounded-full bg-accent/10 px-2 py-0.5 text-xs font-semibold uppercase text-accent">
                Draft
              </span>
            )}
            <p class="text-foreground/70 mt-2 leading-relaxed">{book.data.description}</p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-foreground/60">No books yet. Check back soon.</p>
    )}
  </main>

  <Footer />
</Layout>
