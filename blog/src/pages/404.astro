---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import { SITE } from "@/config";
---

<Layout title={`404 Not Found | ${SITE.title}`}>
  <Header />

  <main
    id="main-content"
    class="mx-auto flex max-w-3xl flex-1 items-center justify-center"
  >
    <div class="mb-14 flex flex-col items-center justify-center">
      <h1 class="text-9xl font-bold text-accent">404</h1>
      <span aria-hidden="true">¯\_(ツ)_/¯</span>
      <p class="mt-4 text-2xl sm:text-3xl">Page Not Found</p>
      <LinkButton
        href="/"
        class="my-6 text-lg underline decoration-dashed underline-offset-8"
      >
        Go back home
      </LinkButton>

      <div class="mt-4 text-center">
        <p class="text-sm uppercase tracking-wider text-foreground/50 mb-3">Or try one of these</p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-sm">
          <a href="/posts" class="text-accent hover:underline decoration-dashed underline-offset-4">Posts</a>
          <span class="text-foreground/30">·</span>
          <a href="/books" class="text-accent hover:underline decoration-dashed underline-offset-4">Books</a>
          <span class="text-foreground/30">·</span>
          <a href="/snippets" class="text-accent hover:underline decoration-dashed underline-offset-4">Snippets</a>
          <span class="text-foreground/30">·</span>
          <a href="/about" class="text-accent hover:underline decoration-dashed underline-offset-4">About</a>
          <span class="text-foreground/30">·</span>
          <a href="/search" class="text-accent hover:underline decoration-dashed underline-offset-4">Search</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
